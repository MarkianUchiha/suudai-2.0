---
// Sección Productos — grid de cards con contador +/-
// Los productos se importan del array hardcodeado
import { products } from '../data/products.js';
---

<section class="products" id="productos">
	<div class="products__container container">
		<h2 class="products__title section-heading">Elige tu Agua</h2>
		<p class="products__subtitle section-subtitle">Selecciona tus productos y haz tu pedido por WhatsApp</p>

		<div class="products__grid">
			{products.map(product => (
				<article class="product-card" data-product-id={product.id} data-price={product.price}>
					<div class="product-card__image-wrapper">
						<img
							src={product.image}
							alt={product.name}
							class="product-card__image"
							width="200"
							height="250"
							loading="lazy"
						/>
					</div>

					<div class="product-card__info">
						<h3 class="product-card__name">{product.name}</h3>
						<span class="product-card__size">{product.size}</span>
						<span class="product-card__price">${product.price}<small> MXN</small></span>
					</div>

					<!-- Contador +/- -->
					<div class="product-card__counter">
						<button
							class="product-card__btn product-card__btn--minus"
							aria-label={`Quitar un ${product.name}`}
							data-action="minus"
						>−</button>
						<span class="product-card__qty" data-qty>0</span>
						<button
							class="product-card__btn product-card__btn--plus"
							aria-label={`Agregar un ${product.name}`}
							data-action="plus"
						>+</button>
					</div>

					<!-- Total por producto (visible cuando qty > 0) -->
					<span class="product-card__total" data-total></span>
				</article>
			))}
		</div>

		<!-- Botón de continuar — abre el modal de pedido -->
		<button type="button" class="btn btn-primary products__checkout" id="checkoutBtn" hidden>
			Continuar con mi pedido
			<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M5 12h14M12 5l7 7-7 7"/>
			</svg>
		</button>
	</div>
</section>

<style>
	.products {
		padding-block: var(--space-3xl);
		background-color: var(--color-bg-light);
	}

	.products__container {
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	/* --- Grid --- */
	.products__grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-lg);
		width: 100%;
		max-width: 400px;
	}

	/* --- Card --- */
	.product-card {
		background-color: var(--color-white);
		border-radius: var(--radius-lg);
		padding: var(--space-lg) var(--space-md);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-sm);
		box-shadow: var(--shadow-sm);
		transition: transform var(--transition-base), box-shadow var(--transition-base);
	}

	.product-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-lg);
	}

	/* Imagen */
	.product-card__image-wrapper {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: var(--space-sm);
	}

	.product-card__image {
		height: 120px;
		width: auto;
		object-fit: contain;
		filter: drop-shadow(0 4px 12px rgba(15, 188, 249, 0.15));
	}


	/* Info */
	.product-card__info {
		text-align: center;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.product-card__name {
		font-size: var(--text-base);
		color: var(--color-primary-dark);
		font-weight: var(--font-semibold);
	}

	.product-card__size {
		font-size: var(--text-sm);
		color: var(--color-text-light);
	}

	.product-card__price {
		font-family: var(--font-heading);
		font-weight: var(--font-bold);
		font-size: var(--text-2xl);
		color: var(--color-secondary);
		margin-top: var(--space-xs);
	}

	.product-card__price small {
		font-size: var(--text-sm);
		font-weight: var(--font-regular);
		color: var(--color-text-light);
	}

	/* --- Contador +/- --- */
	.product-card__counter {
		display: flex;
		align-items: center;
		gap: 0;
		margin-top: var(--space-xs);
	}

	.product-card__btn {
		width: 36px;
		height: 36px;
		border-radius: var(--radius-full);
		font-size: var(--text-xl);
		font-weight: var(--font-bold);
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		transition: background-color var(--transition-fast), color var(--transition-fast);
		user-select: none;
		-webkit-user-select: none;
	}

	.product-card__btn--minus {
		background-color: var(--color-bg-light);
		color: var(--color-text-light);
	}

	.product-card__btn--minus:hover {
		background-color: var(--color-border);
		color: var(--color-text);
	}

	.product-card__btn--plus {
		background-color: var(--color-secondary);
		color: var(--color-white);
	}

	.product-card__btn--plus:hover {
		background-color: var(--color-secondary-light);
	}

	.product-card__qty {
		width: 40px;
		text-align: center;
		font-family: var(--font-heading);
		font-weight: var(--font-bold);
		font-size: var(--text-xl);
		color: var(--color-primary-dark);
	}

	/* Total por producto */
	.product-card__total {
		font-size: var(--text-sm);
		color: var(--color-text-light);
		min-height: 1.2em;
	}

	/* Botón continuar — aparece con animación */
	.products__checkout {
		margin-top: var(--space-xl);
		font-size: var(--text-lg);
		padding: 1rem 2.5rem;
		border-radius: var(--radius-full);
		animation: fadeSlideUp 0.3s ease-out;
	}

	.products__checkout[hidden] {
		display: none;
	}

	@keyframes fadeSlideUp {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}

	/* --- Tablet (768px) --- */
	@media (min-width: 768px) {
		.products {
			padding-block: var(--space-4xl);
		}

		.products__grid {
			grid-template-columns: repeat(3, 1fr);
			gap: var(--space-xl);
			max-width: 800px;
		}

		.product-card__image {
			height: 150px;
		}

		.product-card__name {
			font-size: var(--text-lg);
		}
	}

	/* --- Desktop (1024px) --- */
	@media (min-width: 1024px) {
		.products__grid {
			max-width: 900px;
		}

		.product-card {
			padding: var(--space-xl) var(--space-lg);
		}

		.product-card__image {
			height: 180px;
		}
	}
</style>

<script>
	// Botón de continuar — se muestra cuando hay al menos 1 producto seleccionado
	const checkoutBtn = document.getElementById('checkoutBtn') as HTMLElement;

	// Función para verificar si hay productos seleccionados
	function updateCheckoutBtn() {
		const allQtys = document.querySelectorAll('[data-qty]');
		const hasProducts = Array.from(allQtys).some(el => Number(el.textContent) > 0);

		if (hasProducts) {
			checkoutBtn.removeAttribute('hidden');
		} else {
			checkoutBtn.setAttribute('hidden', '');
		}
	}

	// Lógica de contadores +/- para cada producto
	document.querySelectorAll('.product-card').forEach(card => {
		const price = Number((card as HTMLElement).dataset.price);
		const qtyEl = card.querySelector('[data-qty]') as HTMLElement;
		const totalEl = card.querySelector('[data-total]') as HTMLElement;
		let qty = 0;

		card.querySelectorAll('.product-card__btn').forEach(btn => {
			btn.addEventListener('click', () => {
				const action = (btn as HTMLElement).dataset.action;

				if (action === 'plus' && qty < 20) {
					qty++;
				} else if (action === 'minus' && qty > 0) {
					qty--;
				}

				// Actualiza cantidad visible
				qtyEl.textContent = String(qty);

				// Actualiza total del producto
				if (qty > 0) {
					totalEl.textContent = `Total: $${qty * price} MXN`;
				} else {
					totalEl.textContent = '';
				}

				// Muestra/oculta botón de continuar
				updateCheckoutBtn();
			});
		});
	});
</script>
