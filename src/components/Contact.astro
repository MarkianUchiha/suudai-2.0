---
// Sección de contacto — fondo azul oscuro + Google Maps embed
const phone = '+526181063930';
const phoneDisplay = '+52 618 106 3930';
const email = 'suudai@outlook.com';
const address = 'C. Acuario 102, Valentín Gómez Farías, 34010 Durango, Dgo.';
const facebook = 'https://www.facebook.com/SuudaiDgo';
const mapsLink = 'https://maps.app.goo.gl/Fvim1UUhcS2pGscz7';
// Coordenadas para el embed de Google Maps
const mapsEmbed = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3645.5!2d-104.7001742!3d24.0504464!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x869bc9a3cd17771d%3A0x5e7a098ed8de18b9!2sEmbotelladora%20SUUDAI!5e0!3m2!1ses!2smx!4v1';
---

<section class="contact" id="contacto">
	<div class="contact__container container">
		<div class="contact__info">
			<h2 class="contact__heading">Contáctanos</h2>
			<p class="contact__subtitle">Estamos para servirte</p>

			<!-- Dirección -->
			<div class="contact__item">
				<svg class="contact__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1 1 18 0z"/>
					<circle cx="12" cy="10" r="3"/>
				</svg>
				<div>
					<span class="contact__label">Dirección</span>
					<a href={mapsLink} target="_blank" rel="noopener noreferrer" class="contact__link">{address}</a>
				</div>
			</div>

			<!-- Teléfono -->
			<div class="contact__item">
				<svg class="contact__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
				</svg>
				<div>
					<span class="contact__label">Teléfono</span>
					<a href={`tel:${phone}`} class="contact__link">{phoneDisplay}</a>
				</div>
			</div>

			<!-- Email -->
			<div class="contact__item">
				<svg class="contact__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<rect x="2" y="4" width="20" height="16" rx="2"/>
					<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
				</svg>
				<div>
					<span class="contact__label">Email</span>
					<a href={`mailto:${email}`} class="contact__link">{email}</a>
				</div>
			</div>

			<!-- Redes sociales -->
			<div class="contact__social">
				<a href={facebook} target="_blank" rel="noopener noreferrer" class="contact__social-link" aria-label="Facebook">
					<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
						<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
					</svg>
				</a>
			</div>
		</div>

		<!-- Mapa -->
		<div class="contact__map">
			<iframe
				src={mapsEmbed}
				width="100%"
				height="100%"
				style="border:0;"
				allowfullscreen=""
				loading="lazy"
				referrerpolicy="no-referrer-when-downgrade"
				title="Ubicación de Embotelladora SUUDAI en Google Maps"
			></iframe>
			<a href={mapsLink} target="_blank" rel="noopener noreferrer" class="contact__map-link">
				Abrir en Google Maps →
			</a>
		</div>
	</div>
</section>

<style>
	.contact {
		padding-block: var(--space-3xl);
		background-color: var(--color-primary-dark);
		color: var(--color-white);
	}

	.contact__container {
		display: flex;
		flex-direction: column;
		gap: var(--space-2xl);
	}

	/* --- Info --- */
	.contact__heading {
		color: var(--color-white);
		font-size: var(--text-3xl);
		margin-bottom: var(--space-xs);
	}

	.contact__subtitle {
		color: rgba(255, 255, 255, 0.7);
		margin-bottom: var(--space-xl);
	}

	.contact__item {
		display: flex;
		align-items: flex-start;
		gap: var(--space-md);
		margin-bottom: var(--space-lg);
	}

	.contact__icon {
		width: 24px;
		height: 24px;
		flex-shrink: 0;
		margin-top: 2px;
		stroke: var(--color-secondary);
	}

	.contact__label {
		display: block;
		font-size: var(--text-sm);
		color: rgba(255, 255, 255, 0.6);
		margin-bottom: 2px;
	}

	.contact__link {
		color: var(--color-white);
		transition: color var(--transition-fast);
	}

	.contact__link:hover {
		color: var(--color-secondary);
	}

	/* --- Redes sociales --- */
	.contact__social {
		display: flex;
		gap: var(--space-md);
		margin-top: var(--space-lg);
	}

	.contact__social-link {
		width: 44px;
		height: 44px;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 2px solid rgba(255, 255, 255, 0.3);
		border-radius: 50%;
		color: var(--color-white);
		transition: border-color var(--transition-fast), color var(--transition-fast), background-color var(--transition-fast);
	}

	.contact__social-link:hover {
		border-color: var(--color-secondary);
		color: var(--color-secondary);
		background-color: rgba(18, 203, 196, 0.1);
	}

	.contact__social-link svg {
		width: 20px;
		height: 20px;
	}

	/* --- Mapa --- */
	.contact__map {
		position: relative;
		border-radius: var(--radius-lg);
		overflow: hidden;
		min-height: 300px;
	}

	.contact__map iframe {
		display: block;
		width: 100%;
		height: 100%;
		min-height: 300px;
	}

	.contact__map-link {
		position: absolute;
		bottom: var(--space-md);
		right: var(--space-md);
		background-color: var(--color-primary-dark);
		color: var(--color-white);
		padding: 0.5rem 1rem;
		border-radius: var(--radius-md);
		font-size: var(--text-sm);
		font-weight: var(--font-semibold);
		transition: background-color var(--transition-fast);
	}

	.contact__map-link:hover {
		background-color: var(--color-secondary);
	}

	/* --- Tablet/Desktop --- */
	@media (min-width: 768px) {
		.contact {
			padding-block: var(--space-4xl);
		}

		.contact__container {
			flex-direction: row;
			align-items: stretch;
		}

		.contact__info {
			flex: 1;
		}

		.contact__map {
			flex: 1;
			min-height: 400px;
		}
	}
</style>
