---
// Layout base — envuelve todas las páginas
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import OrderModal from '../components/OrderModal.astro';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Suudai — Agua Purificada a Domicilio en Durango',
	description = 'Pide agua purificada a domicilio en Durango. Garrafones de 20L, botellas de 500ml y 1.5L. Pedidos por WhatsApp, entrega al día siguiente. Más de 20,000 clientes satisfechos.',
} = Astro.props;

const siteUrl = 'https://suudai.com';
const ogImage = `${siteUrl}/images/garrafon-hero.png`;
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:url" content={siteUrl} />
		<meta property="og:locale" content="es_MX" />
		<meta property="og:site_name" content="Suudai" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

		<!-- Canonical -->
		<link rel="canonical" href={siteUrl} />

		<!-- Precarga de fuentes para rendimiento -->
		<link rel="preload" href="/fonts/instrument-sans-variable.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/poppins-400.woff2" as="font" type="font/woff2" crossorigin />

		<!-- JSON-LD: Negocio local -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "LocalBusiness",
			"name": "Suudai — Agua Purificada",
			"description": "Agua purificada a domicilio en Durango. Garrafones y botellas con entrega al día siguiente.",
			"url": siteUrl,
			"telephone": "+526181063930",
			"email": "suudai@outlook.com",
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "C. Acuario 102, Valentín Gómez Farías",
				"addressLocality": "Durango",
				"addressRegion": "Dgo.",
				"postalCode": "34010",
				"addressCountry": "MX"
			},
			"geo": {
				"@type": "GeoCoordinates",
				"latitude": 24.0504464,
				"longitude": -104.6975993
			},
			"openingHours": "Mo-Sa 08:00-18:00",
			"priceRange": "$",
			"image": ogImage,
			"sameAs": [
				"https://www.facebook.com/SuudaiDgo"
			]
		})} />
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
		<OrderModal />
	</body>
</html>
